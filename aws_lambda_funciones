# 3. Función principal (Ahora súper simplificada y segura)
def lambda_handler(event, context):
    print("🔔 Webhook recibido de Telegram!")
    try:
        cuerpo = json.loads(event['body'])
        update = telebot.types.Update.de_json(cuerpo)
        
        # ⚡ ESTA LÍNEA ES LA MAGIA QUE FALTABA ⚡
        # Le dice a Telebot: "Oye, revisa si es un mensaje o un botón y repártelo"
        bot.process_new_updates([update])
        
    except Exception as e:
        print(f"❌ Error procesando el webhook: {e}")
    
    return {
        'statusCode': 200,
        'body': json.dumps('Mensaje procesado con éxito')
    }
