#CODIGO LIMPIEZA:

import json
import urllib.parse
import boto3
import pandas as pd
import io
import ast

# 1. Conectamos con S3
s3_client = boto3.client('s3')

# 🛡️ Función escudo: Evita que Lambda se rompa si PcComponentes envía un dato nulo o raro
def safe_eval(val):
    try:
        return ast.literal_eval(str(val))
    except (ValueError, SyntaxError, TypeError):
        return {}

def lambda_handler(event, context):
    try:
        # ==========================================
        # 1. SABER QUÉ ARCHIVO DESPERTÓ A LA LAMBDA
        # ==========================================
        bucket_origen = event['Records'][0]['s3']['bucket']['name']
        archivo_key = urllib.parse.unquote_plus(event['Records'][0]['s3']['object']['key'])
        
        # Filtro de seguridad: Solo actuamos si el archivo está en la carpeta 'bronze'
        if not archivo_key.startswith("bronze/"):
            print(f"Ignorando archivo fuera de la capa bronze: {archivo_key}")
            return {'statusCode': 200, 'body': 'Ignorado (No es capa Bronze)'}
            
        print(f"📥 Descargando a la memoria: {archivo_key}")

        # ==========================================
        # 2. LEER DATOS CRUDOS DESDE S3
        # ==========================================
        respuesta_s3 = s3_client.get_object(Bucket=bucket_origen, Key=archivo_key)
        datos_crudos = respuesta_s3['Body'].read()
        
        # Leemos el CSV directamente en la memoria RAM de Lambda
        df_bronze = pd.read_csv(io.BytesIO(datos_crudos))

        # ==========================================
        # 3. 🧼 PROCESO DE LIMPIEZA (CAPA SILVER)
        # ==========================================
        columnas_deseadas = {
            'name': 'Nombre',
            'price': 'Precio_Actual',
            'referencePrice': 'Precio_Original',
            'discount': 'Descuento',
            'ratingAvg': 'Valoracion',
            'ratingCount': 'Opiniones',
            'mainCategory': 'Categoria',     
            'slug': 'Ruta_Producto',         
            'Fecha_Extraccion': 'Fecha',
            'wishListCounter': 'Interesados_Wishlist', 
            'visitsLast30Days': 'Visitas_Mensuales',   
            'isPcCom': 'Vendido_Por_PcCom'             
        }

        # Filtramos y renombramos
        columnas_presentes = [col for col in columnas_deseadas.keys() if col in df_bronze.columns]
        df_silver = df_bronze[columnas_presentes].rename(columns=columnas_deseadas)

        # Arreglar la URL completa
        if 'Ruta_Producto' in df_silver.columns:
            df_silver['URL_Completa'] = "https://www.pccomponentes.com/" + df_silver['Ruta_Producto'].astype(str)
            df_silver = df_silver.drop(columns=['Ruta_Producto'])

        # Limpieza de nulos y formatos de fecha
        df_silver['Valoracion'] = df_silver['Valoracion'].fillna(0)
        df_silver['Fecha'] = pd.to_datetime(df_silver['Fecha'], errors='coerce')
        df_silver['Hora'] = df_silver['Fecha'].dt.time
        df_silver['Fecha'] = df_silver['Fecha'].dt.date

        # Ordenar (Cazachollos)
        df_silver.sort_values(
            by=['Descuento', 'Precio_Actual', 'Valoracion'], 
            ascending=[False, True, False], 
            inplace=True
        )

        # Extraer Diccionario de Categorías usando nuestra función escudo (safe_eval)
        df_silver['Categoria'] = df_silver['Categoria'].apply(safe_eval)

        # Extraer nombre y slug
        df_silver['Categoria_nombre'] = df_silver['Categoria'].apply(lambda x: x.get('name', 'Sin categoría') if isinstance(x, dict) else 'Sin categoría')
        df_silver['Categoria_slug'] = df_silver['Categoria'].apply(lambda x: x.get('slug', 'Sin clave') if isinstance(x, dict) else 'Sin categoría')

        # Borrar diccionario original
        df_silver = df_silver.drop(columns=['Categoria'])

        # ==========================================
        # 4. GUARDAR EN S3 (CARPETA SILVER)
        # ==========================================
        # Cambiamos la ruta de "bronze/archivo.csv" a "silver/archivo_clean.csv"
        nuevo_nombre = archivo_key.replace("bronze/", "silver/").replace(".csv", "_clean.csv")
        
        # Convertimos el DataFrame a texto CSV en la memoria
        csv_buffer = io.StringIO()
        df_silver.to_csv(csv_buffer, index=False)
        
        # Subimos el archivo final a la carpeta silver de tu bucket
        s3_client.put_object(
            Bucket=bucket_origen, 
            Key=nuevo_nombre, 
            Body=csv_buffer.getvalue()
        )
        
        print(f"✅ ¡Éxito! Archivo guardado en la capa Silver: {nuevo_nombre}")
        return {
            'statusCode': 200, 
            'body': json.dumps(f'Procesado correctamente: {nuevo_nombre}')
        }
        
    except Exception as e:
        print(f"❌ Error crítico procesando el archivo: {str(e)}")
        raise e

