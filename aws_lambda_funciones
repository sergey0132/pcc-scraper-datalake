# --- 👇 AÑADIDO: ESCUCHADOR DE MENSAJES DE TEXTO 👇 ---
@bot.message_handler(func=lambda message: True)
def procesar_mensaje(message):
    chat_id = message.chat.id
    texto_usuario = message.text
    
    df = cargar_datos()
    if df is None:
         bot.send_message(chat_id, "Lo siento, ahora mismo no puedo acceder a las ofertas. Inténtalo más tarde.")
         return
         
    if texto_usuario in df['Categoria_nombre'].unique():
        bot.send_message(chat_id, f"🔎 Buscando las mejores ofertas en *{texto_usuario}*...", parse_mode="Markdown")
        ofertas = df[df['Categoria_nombre'] == texto_usuario].sort_values(by='Descuento', ascending=False).head(5)
        
        for _, row in ofertas.iterrows():
            card = (
                    f"🔥 *{row['Nombre']}*\n\n"
                    f"💰 *Precio:* {row['Precio_Actual']}€ ~~(Antes: {row['Precio_Original']}€)~~\n"
                    f"📉 *Descuento:* {row['Descuento']}%\n"
                    f"⭐ *Valoración:* {row['Valoracion']}/5\n\n"
                    f"🔗 *[Ver en PC Componentes]*({row['URL_Completa']})"
                )
            bot.send_message(chat_id, card, parse_mode="Markdown", disable_web_page_preview=False)
        
        markup_opciones = telebot.types.InlineKeyboardMarkup()
        btn_mas = telebot.types.InlineKeyboardButton("➕ Ver mas ofertas", callback_data=f"mas_{texto_usuario}")
        btn_menu = telebot.types.InlineKeyboardButton("🏠 Otras categorías", callback_data="menu_principal")
        markup_opciones.row(btn_mas, btn_menu)
        bot.send_message(chat_id, "¿Qué quieres hacer ahora?", reply_markup=markup_opciones)
    else:
        respuesta = "¡Hola! Soy tu bot de ofertas. 🤖\n\n¿Qué categoría te gustaría explorar hoy?"
        bot.send_message(chat_id, respuesta, reply_markup=crear_menu_categorias(df))
