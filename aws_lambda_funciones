#CODIGO BOT-TELEGRAM:

import os
import json
import boto3
import io
import pandas as pd
import telebot
from telebot import types

# 🔑 TUS CREDENCIALES
TOKEN = 'TU-TOKEN' 
bot = telebot.TeleBot(TOKEN, threaded=False)

# ☁️ CONFIGURACIÓN S3
NOMBRE_BUCKET = 'NOMBRE-BUCKET' 
s3_client = boto3.client('s3')

# 1. Función para cargar los datos DESDE S3 (con Caché y Radar)
df_cache = None

def cargar_datos():
    global df_cache
    if df_cache is not None:
        return df_cache 
        
    try:
        print("☁️ Buscando el archivo de chollos más reciente en S3...")
        respuesta_lista = s3_client.list_objects_v2(Bucket=NOMBRE_BUCKET, Prefix='silver/')
        archivos_csv = [archivo for archivo in respuesta_lista.get('Contents', []) if archivo['Key'].endswith('.csv')]
        
        if not archivos_csv:
            print("❌ No se encontraron archivos CSV en la carpeta silver/")
            return None
            
        archivos_csv.sort(key=lambda x: x['LastModified'], reverse=True)
        archivo_mas_reciente = archivos_csv[0]['Key']
        print(f"✅ Archivo más nuevo encontrado: {archivo_mas_reciente}")

        respuesta = s3_client.get_object(Bucket=NOMBRE_BUCKET, Key=archivo_mas_reciente)
        datos_csv = respuesta['Body'].read()
        
        df = pd.read_csv(io.BytesIO(datos_csv))
        df = df.drop_duplicates(subset=['Nombre'])
        df_cache = df 
        return df
        
    except Exception as e:
        print(f"❌ Error S3: {e}")
        return None

# 2. Menú principal (Teclado inferior)
def crear_menu_categorias(df):
    markup = types.ReplyKeyboardMarkup(row_width=2, resize_keyboard=True)
    if df is not None:
        categorias = df['Categoria_nombre'].unique().tolist()
        botones = [types.KeyboardButton(cat) for cat in categorias]
        markup.add(*botones)
    return markup


# --- 👇 AÑADIDO: ESCUCHADOR DE BOTONES INLINE 👇 ---
@bot.callback_query_handler(func=lambda call: True)
def procesar_botones(call):
    chat_id = call.message.chat.id
    datos = call.data
    
    df = cargar_datos()
    
    if datos == "menu_principal":
        bot.answer_callback_query(call.id) 
        bot.send_message(chat_id, "¡Aquí tienes todas las categorías!", reply_markup=crear_menu_categorias(df))
        
    elif datos.startswith("mas_"):
        bot.answer_callback_query(call.id)
        categoria = datos.replace("mas_", "")
        
        todas_las_ofertas = df[df['Categoria_nombre'] == categoria].sort_values(by='Descuento', ascending=False)
        siguientes_ofertas = todas_las_ofertas.iloc[5:10]
        
        if siguientes_ofertas.empty:
            bot.send_message(chat_id, "¡Vaya! Ya no hay más chollos en esta categoría. 😅", reply_markup=crear_menu_categorias(df))
        else:
            bot.send_message(chat_id, f"🔎 Buscando 5 chollos MÁS en *{categoria}*...", parse_mode="Markdown")
            for _, row in siguientes_ofertas.iterrows():
                card = (
                        f"🔥 *{row['Nombre']}*\n\n"
                        f"💰 *Precio:* {row['Precio_Actual']}€ ~~(Antes: {row['Precio_Original']}€)~~\n"
                        f"📉 *Descuento:* {row['Descuento']}%\n"
                        f"⭐ *Valoración:* {row['Valoracion']}/5\n\n"
                        f"🔗 *[Ver en PC Componentes]*({row['URL_Completa']})"
                    )
                bot.send_message(chat_id, card, parse_mode="Markdown", disable_web_page_preview=False)
            
            markup_volver = telebot.types.InlineKeyboardMarkup()
            btn_volver = telebot.types.InlineKeyboardButton("🏠 Volver a las categorías", callback_data="menu_principal")
            markup_volver.add(btn_volver)
            bot.send_message(chat_id, "Esos son todos los mejores chollos.", reply_markup=markup_volver)
